# 忽略日志文件
*.log

# 忽略锁文件
*.lock

# 忽略临时文件
tmp/
*.tmp

# 忽略敏感配置（如果需要）
# config/secrets.env

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略IDE配置
.vscode/
.idea/

# 忽略Node.js依赖（如果存在）
node_modules/

# 忽略Python虚拟环境（如果存在）
venv/
__pycache__/

# 注意：scripts目录包含敏感信息（如Telegram bot token）
# 如果需要排除整个scripts目录，取消下面的注释
# scripts/

*.sh